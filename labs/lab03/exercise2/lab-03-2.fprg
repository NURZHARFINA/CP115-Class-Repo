<?xml version="1.0"?>
<flowgorithm fileversion="4.2">
    <attributes>
        <attribute name="name" value="lab-03-2"/>
        <attribute name="authors" value="User"/>
        <attribute name="about" value=""/>
        <attribute name="saved" value="2026-07-08 11:57:29 AM"/>
        <attribute name="created" value="VXNlcjtERVNLVE9QLUozOVAxTlQ7MjAyNi0wNy0wODsxMTo0NjowMSBBTTsyNzM4"/>
        <attribute name="edited" value="VXNlcjtERVNLVE9QLUozOVAxTlQ7MjAyNi0wNy0wODsxMTo1NzoyOSBBTTsyOzI4NTk="/>
    </attributes>
    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="NumOfNight" type="Integer" array="False" size=""/>
            <input variable="NumOfNight"/>
            <declare name="totalPayment" type="Integer" array="False" size=""/>
            <declare name="price" type="Integer" array="False" size=""/>
            <input variable="price"/>
            <assign variable="price" expression="250 * NumOfNight"/>
            <assign variable="totalPayment" expression="price + ( price * 0.15 )"/>
            <output expression="totalPayment" newline="True"/>
        </body>
    </function>
</flowgorithm>
